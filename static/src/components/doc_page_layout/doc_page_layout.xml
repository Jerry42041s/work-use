<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dobtor_doc_editor.DocPageLayout">
        <!--
            多頁文件容器（新架構）：
            - .doc-editor-stage：灰色背景捲動區
            - 頁首/頁尾：Stage 頂端/底端的獨立可編輯區
            - 主內容：Wysiwyg 掛載於 .doc-content-area，
              PaginationController 在 contenteditable 內動態建立 .doc-page-sheet
        -->
        <div class="doc-editor-stage" t-att-style="stageStyle">

            <!-- ── 頁首（stage 頂端，對齊紙張寬度）── -->
            <div class="doc-hf-outer doc-header-outer"
                 t-att-style="hfContainerStyle"
                 t-ref="headerArea"
                 t-on-dblclick="onHeaderDblClick">
                <span class="doc-hf-label doc-header-label">頁首</span>
                <t t-if="state.editingHeader">
                    <Wysiwyg config="headerEditorConfig"/>
                </t>
                <t t-else="">
                    <div t-out="props.headerHtml or ''" class="doc-hf-readonly"/>
                    <t t-if="!props.headerHtml">
                        <span class="doc-hf-placeholder">雙擊編輯頁首</span>
                    </t>
                </t>
            </div>

            <!-- ── 主內容區（PaginationController 在此建立多個 .doc-page-sheet）── -->
            <div class="doc-content-area" t-ref="pageContent">
                <t t-if="props.editorConfig">
                    <Wysiwyg config="props.editorConfig"/>
                </t>
            </div>

            <!-- ── 頁尾（stage 底端，對齊紙張寬度）── -->
            <div class="doc-hf-outer doc-footer-outer"
                 t-att-style="hfContainerStyle"
                 t-ref="footerArea"
                 t-on-dblclick="onFooterDblClick">
                <span class="doc-hf-label doc-footer-label">頁尾</span>
                <t t-if="state.editingFooter">
                    <Wysiwyg config="footerEditorConfig"/>
                </t>
                <t t-else="">
                    <div t-out="props.footerHtml or ''" class="doc-hf-readonly"/>
                    <t t-if="!props.footerHtml">
                        <span class="doc-hf-placeholder">雙擊編輯頁尾</span>
                    </t>
                </t>
            </div>

            <!-- ── 頁數角標（右下角）── -->
            <t t-if="state.totalPages > 1">
                <div class="doc-page-count-badge">
                    共 <t t-esc="state.totalPages"/> 頁
                </div>
            </t>

        </div>
    </t>
</templates>
