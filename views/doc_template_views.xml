<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ─── 範本列表 Action ─── -->
    <record id="action_doc_template_list" model="ir.actions.act_window">
        <field name="name">文件範本</field>
        <field name="res_model">doc.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立第一個文件範本
            </p>
        </field>
    </record>

    <!-- ─── 範本列表 View ─── -->
    <record id="view_doc_template_list" model="ir.ui.view">
        <field name="name">doc.template.list</field>
        <field name="model">doc.template</field>
        <field name="arch" type="xml">
            <list string="文件範本">
                <field name="name"/>
                <field name="category"/>
                <field name="model_id" optional="show"/>
                <field name="page_format" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ─── 範本表單 View ─── -->
    <record id="view_doc_template_form" model="ir.ui.view">
        <field name="name">doc.template.form</field>
        <field name="model">doc.template</field>
        <field name="arch" type="xml">
            <form string="文件範本">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="範本名稱" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category" string="分類"/>
                            <field name="model_id" string="適用模型"/>
                            <field name="page_format" string="預設頁面格式"/>
                            <field name="active" string="啟用"/>
                        </group>
                        <group>
                            <field name="description" string="說明" widget="text"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="範本內容">
                            <field name="content_html"
                                   widget="html"
                                   options="{'resizable': true}"
                                   style="min-height: 400px;"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── 搜尋 View ─── -->
    <record id="view_doc_template_search" model="ir.ui.view">
        <field name="name">doc.template.search</field>
        <field name="model">doc.template</field>
        <field name="arch" type="xml">
            <search string="搜尋範本">
                <field name="name"/>
                <field name="model_id"/>
                <filter name="active" string="啟用" domain="[('active', '=', True)]"/>
                <group expand="0" string="分組依據">
                    <filter name="group_by_category"
                            string="分類"
                            context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
